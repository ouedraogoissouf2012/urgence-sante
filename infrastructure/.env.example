# Copiez ce fichier en « .env » et renseignez vos valeurs locales.
# Le fichier .env est ignoré par git (voir .gitignore) : aucun secret versionné.

POSTGRES_DB=urgence_sante
POSTGRES_USER=urgence_sante
# Choisissez un mot de passe local (n'importe quelle valeur pour le développement).
POSTGRES_PASSWORD=changez_moi_en_local
POSTGRES_PORT=5432
