<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.urgencesante</groupId>
        <artifactId>backend</artifactId>
        <version>0.1.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>bootstrap</artifactId>
    <name>Urgence Santé — Bootstrap</name>
    <description>Assemblage et démarrage de l'application Spring Boot</description>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>

        <!--
          Assemblage des modules métier. building-blocks arrive transitivement.
          C'est le seul point du dépôt qui réunit tous les modules.
        -->
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>facility</artifactId>
        </dependency>
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>medical-service</artifactId>
        </dependency>
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>availability</artifactId>
        </dependency>
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>routing</artifactId>
        </dependency>
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>orientation</artifactId>
        </dependency>
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>identity</artifactId>
        </dependency>
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>audit</artifactId>
        </dependency>
        <dependency>
            <groupId>com.urgencesante</groupId>
            <artifactId>notification</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Seul le module d'assemblage produit un exécutable repackagé. -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
