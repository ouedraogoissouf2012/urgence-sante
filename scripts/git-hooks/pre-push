#!/usr/bin/env bash
#
# Hook pre-push : exécute les gardes de qualité et d'architecture avant tout
# push. C'est l'équivalent local de .github/workflows/ci.yml, utile tant que les
# minutes GitHub Actions ne sont pas disponibles sur le dépôt privé.
#
# Activation (une fois par clone) :
#   git config core.hooksPath scripts/git-hooks
#
# Contournement d'urgence (à éviter, non tracé) :
#   git push --no-verify
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "▶ Garde 1/3 — limite de 300 lignes"
bash scripts/check-file-length.sh

echo ""
echo "▶ Garde 2/3 — build, tests et vérification d'architecture (backend)"
( cd backend && ./mvnw -B --no-transfer-progress verify )

echo ""
echo "▶ Garde 3/3 — analyse et tests Flutter (frontend)"
(
  cd frontend
  flutter pub get >/dev/null
  flutter analyze
  for member in \
      packages/app_foundation packages/design_system packages/api_client \
      apps/patient_mobile apps/hospital_portal; do
    ( cd "$member" && flutter test )
  done
)

echo ""
echo "✓ Gardes locales OK — push autorisé."
